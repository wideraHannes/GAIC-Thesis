# API Keys for LLM providers
# Copy this file to .env and fill in your keys

# OpenAI (required for GPT-5.2)
OPENAI_API_KEY=sk-...

# Mistral AI (required for Ministral/Mistral Medium)
MISTRAL_API_KEY=...

# Portkey (optional, for Azure OpenAI gateway)
PORTKEY_API_KEY=...

# Weights & Biases (optional, for experiment tracking)
WANDB_API_KEY=...

# Alternative providers (optional)
GROQ_API_KEY=...
TOGETHER_API_KEY=...
OLLAMA_API_KEY=...
